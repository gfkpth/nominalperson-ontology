########################
# Importing namespaces
########################

@prefix nompers: <https://w3id.org/nompers#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix geo: <https://www.w3.org/2003/01/geo/#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .


#########################
# Metadata for ontology
#########################

nompers: a owl:Ontology ;
    dct:title "Nominal Person Ontology (NomPersOnt)" ;
    dct:creator "Georg F.K. Höhn" ;
    dct:created "2026-03-31"^^xsd:date ;
    owl:versionIRI <https://w3id.org/nompers/0.0.2> ;
    owl:versionInfo "0.0.2" ;
    dct:modified "2026-04-07"^^xsd:date ;
    dct:publisher <https://morelight.goip.de> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:description "An ontology for a crosslinguistic typology of adnominal person marking." ;
    rdfs:seeAlso <https://github.com/gfkpth/nompers-ontology> ;
    rdfs:seeAlso <https://zenodo.org/records/16605840> ;
    owl:imports <http://www.w3.org/2004/02/skos/core> .

################################
# Languoid-related definitions
################################

# ======================================================================
# Class: nompers:Languoid
# ======================================================================
# generic languoid class
# simplistic implementation of genealogical relationships using three disjoint subclasses 
# nompers:Language, nompers:Genus and nompers:Family are 

nompers:Languoid a owl:Class ;
    rdfs:label "Languoid" ;
    rdfs:comment "Abstract superclass for language-like entities" ;
    owl:disjointUnionOf (nompers:Language nompers:Genus nompers:Family) ;
    rdfs:subClassOf skos:Concept .


# ----------------------------------------------------------------------
#   Properties for nompers:Languoid
# ----------------------------------------------------------------------

nompers:inRegion a owl:ObjectProperty ;
    rdfs:label "in region" ;
    rdfs:comment "Region in which a languoid is attested" ;
    rdfs:domain nompers:Languoid ;
    rdfs:range nompers:Region .

# for now just model glottocode and WALS-id as strings
nompers:hasGlottocode a owl:DatatypeProperty, owl:FunctionalProperty, owl:InverseFunctionalProperty ;
    rdfs:label      "Glottocode" ;
    rdfs:comment    "Glottolog identifier. URI pattern: http://glottolog.org/resource/languoid/id/{glottocode}" ;
    rdfs:isDefinedBy <https://glottolog.org> ;
    rdfs:domain     nompers:Languoid ;
    rdfs:range      xsd:string .


# Using isTerminal property for identifying "languages" as opposed to language family nodes
# This could be refined for more elegant capturing of "dialects", but will do for now
nompers:isTerminal a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label      "is terminal" ;
    rdfs:comment    "Indicates whether a languoid is a terminal node." ;
    rdfs:domain     nompers:Languoid ;
    rdfs:range      xsd:boolean .



# ======================================================================
# Class: nompers:Language (terminal Languoid)
# ======================================================================

nompers:Language a owl:Class ;
    rdfs:label "Language" ;
    rdfs:comment "A languoid terminal node" ;
    rdfs:subClassOf nompers:Languoid ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty nompers:isTerminal ;
        owl:hasValue true
    ] .


# ----------------------------------------------------------------------
#   Properties for nompers:Language
# ----------------------------------------------------------------------

# simplified implementation of genealogical hierarchies 
# to be removed if need for recursive Languoid structuring of genealogical trees arises
nompers:inGenus a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain nompers:Language ;
    rdfs:range nompers:Genus ;
    rdfs:label "member of genus" ;
    rdfs:comment "Relates a language to the genus it belongs to." .

nompers:inFamily a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain nompers:Language ;
    rdfs:range nompers:Family ;
    rdfs:label "member of language family" ;
    rdfs:comment "Relates a language to the family it belongs to." .
 

nompers:hasWalsId   a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label      "WALS ID" ;
    rdfs:comment    "WALS identifier. URI pattern: https://wals.info/languoid/lect/wals_code_{walscode}" ;
    rdfs:isDefinedBy <https://wals.info> ;
    rdfs:domain     nompers:Language ;
    rdfs:range      xsd:string .

nompers:hasIso639P3Code a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:domain nompers:Language ;
    rdfs:range xsd:string ;
    rdfs:comment    "Language identifier following ISO 639-3. URI pattern: https://iso639-3.sil.org/code/{iso639_3code}" ;
    rdfs:isDefinedBy <https://iso639-3.sil.org/> ;
    rdfs:label "ISO 639-3 Code" .

nompers:hasCoordinates a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:label "has coordinates" ;
    rdfs:domain nompers:Language ;
    rdfs:range geo:Point .

# ======================================================================
#  Class nompers:Genus
# ======================================================================

nompers:Genus a owl:Class ;
    rdfs:subClassOf nompers:Languoid ;
    rdfs:subClassOf [a owl:Restriction ;
            owl:onProperty nompers:isTerminal ;
            owl:hasValue false ] ;
    rdfs:label "Genus" ;
    rdfs:comment "A genus-level languoid. While decisions as to what tree depth counts as a genus is somewhat arbitrary, an intermediate level of genealogical relations is useful. This follows the practice (and largely the assignments) of WALS. Names for genus instances should be provided with skos:prefLabel/skos:altLabel relations." .

nompers:hasGenusMember a owl:ObjectProperty ;
    owl:inverseOf nompers:inGenus ;
    rdfs:label "has language member" ;
    rdfs:domain nompers:Genus ;
    rdfs:range nompers:Language .

nompers:hasFamilyMember a owl:ObjectProperty ;
    owl:inverseOf nompers:inFamily ;
    rdfs:label "has family member" ;
    rdfs:domain nompers:Family ;
    rdfs:range nompers:Language .

# ======================================================================
#  Class nompers:Family
# ======================================================================

nompers:Family a owl:Class ;
    rdfs:subClassOf nompers:Languoid ;
    rdfs:subClassOf [a owl:Restriction ;
            owl:onProperty nompers:isTerminal ;
            owl:hasValue "False" ] ;
    rdfs:label "Language family" ;
    rdfs:comment "A family-level languoid. Names for family instances should be provided with skos:prefLabel/skos:altLabel relations." .


# ======================================================================
# Class: nompers:Region
# ======================================================================

nompers:Region a owl:Class ;
    rdfs:label "Region" ;
    rdfs:comment "Generic geographical region (superclass)" .


nompers:RegionGlottolog a owl:Class ;
    rdfs:subClassOf nompers:Region ;
    rdfs:label "Region (Glottolog)" ;
    rdfs:comment "Geographical region as defined in Glottolog" ;
    rdfs:seeAlso <https://glottolog.org/meta/glossary#macroarea> .

nompers:RegionWALS a owl:Class ;
    rdfs:subClassOf nompers:Region ;
    rdfs:label "Region (WALS)" ;
    rdfs:comment "Geographical region as defined in WALS" .




# ======================================================================
# Class: nompers:Parameter
# ======================================================================
nompers:Parameter a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Parameter" ;
    rdfs:comment "A linguistic parameter. Uses skos:prefLabel for the canonical name and skos:definition for the description." ;
    rdfs:subClassOf [ 
        a owl:Restriction ;
        owl:onProperty nompers:hasPotentialValue ;
        owl:minCardinality 1 
    ] .

# ----------------------------------------------------------------------
#   Properties for nompers:Parameter
# ----------------------------------------------------------------------
nompers:hasPotentialValue a owl:ObjectProperty ;
    rdfs:label "has potential value" ;
    rdfs:comment "A possible value of the parameter" ;
    rdfs:domain nompers:Parameter ;
    rdfs:range nompers:ParameterValue .



# ======================================================================
# Class: nompers:ParameterValue
# ======================================================================
nompers:ParameterValue a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Parameter value" ;
    rdfs:comment "The value of a parameter. Uses skos:prefLabel for the canonical name and skos:definition for the description." .


# ----------------------------------------------------------------------
#   Properties for nompers:ParameterValue
# ----------------------------------------------------------------------

nompers:isPotentialValueOf a owl:ObjectProperty ;
    owl:inverseOf nompers:hasPotentialValue ;
    rdfs:label "is potential value of" ;
    rdfs:comment "Relates a value to a parameter" .

# ======================================================================
# Class: nompers:Source
# ======================================================================

nompers:Source a owl:Class ;
    rdfs:label "Source" ;
    rdfs:comment "A source" .

# ----------------------------------------------------------------------
#   Properties for nompers:Source
# ----------------------------------------------------------------------

nompers:hasBibtex a owl:DatatypeProperty ;
    rdfs:domain nompers:Source ;
    rdfs:range xsd:string ;
    rdfs:label "has bibtex" ;
    rdfs:comment "BibTeX string for a data source" .


nompers:hasPage a owl:DatatypeProperty ;
    rdfs:label "has page" ;
    rdfs:comment "Page range for data source" ;
    rdfs:domain nompers:Source ;
    rdfs:range xsd:string .

# ======================================================================
# Class: nompers:ParameterAssociation
# ======================================================================

nompers:ParameterAssociation  a owl:Class ;
    rdfs:label "Parameter association" ;
    rdfs:comment "Relates a parameter + value to a languoid" .


# ----------------------------------------------------------------------
#   Properties for nompers:ParameterAssociation
# ----------------------------------------------------------------------

nompers:relatesLanguoid  a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain nompers:ParameterAssociation ;
    rdfs:range nompers:Languoid ;
    rdfs:label "for languoid" ;
    rdfs:comment "Relates a parameter association to a languoid" .

nompers:relatesParameter     a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain nompers:ParameterAssociation ;
    rdfs:range nompers:Parameter ;
    rdfs:label "relates Parameter" ;
    rdfs:comment "Relates a parameter association to a parameter" .
    
nompers:relatesParameterValue  a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain nompers:ParameterAssociation ;
    rdfs:range nompers:ParameterValue ;
    rdfs:label "relates ParameterValue" ;
    rdfs:comment "Relates a parameter association to a parameter value" .


nompers:sourcedFrom a owl:ObjectProperty ;
    rdfs:label "sourced from" ;
    rdfs:comment "Bibliographic source for a parameter association or example" ;
    rdfs:range nompers:Source .


nompers:exemplifiedBy a owl:ObjectProperty ;
    rdfs:label "examplified by" ;
    rdfs:comment "Relates a parameter association to an example illustrating the specific parameter value for a given language" ;
    rdfs:domain nompers:ParameterAssociation ;
    rdfs:range nompers:Example .

# ================================================

nompers:Example rdf:type owl:Class ;
    rdfs:label "Example" ;
    rdfs:comment "Represents a linguistic example from a language." .


nompers:inLanguoid rdf:type owl:ObjectProperty ;
    rdfs:label "from Languoid" ;
    rdfs:comment "Indicates the language of the example" ;
    rdfs:domain nompers:Example ;
    rdfs:range nompers:Languoid .

# Properties for Example
nompers:primaryText a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain nompers:Example ;
    rdfs:range xsd:string ;
    rdfs:label "Primary Text" ;
    rdfs:comment "The example text in the source language." .

nompers:analyzedWord a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain nompers:Example ;
    rdfs:range rdf:List;
    rdfs:label "Analyzed Word" ;
    rdfs:comment "The example text analysed into morphemes. Stored as string, tabs are used for alignment with nompers:gloss" .

nompers:gloss a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain nompers:Example ;
    rdfs:range xsd:string ;
    rdfs:label "Gloss" ;
    rdfs:comment "Glossing of an example. Stored as string, tabs are used for alignment with nompers:analyzedWord." .

nompers:translatedText a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain nompers:Example ;
    rdfs:range xsd:string ;
    rdfs:label "Translation" ;
    rdfs:comment "Translation of an example." .

# ===================================================

nompers:CoreParameter a owl:Class ;
    rdfs:subClassOf nompers:Parameter ;
    rdfs:label "Core parameter" ;
    rdfs:comment "A parameter directly describing nominal person constructions." .

nompers:ControlParameter a owl:Class ;
    rdfs:subClassOf nompers:Parameter ;
    rdfs:label "Control parameter" ;
    rdfs:comment "A typological control variable (e.g. word order) included for comparative analysis." .